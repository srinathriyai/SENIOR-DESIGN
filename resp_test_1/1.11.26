#include <Arduino.h>

/* ---------Serial + Sensor----------*/
// Baud rate for Serial Monitor communication
static const uint32_t BAUD = 115200;
// Analog pin connected to the stretch respiration sensor
static const uint8_t  SENSOR_PIN = A0;

/* ----------Sampling & Filtering----------*/
static const uint16_t SAMPLE_MS = 40;       // Time between samples (ms) 
static const float    FILTER_ALPHA = 0.12f; // Low-pass filter (smoothing (Smaller = smoother but slower, larger = faster but noisier))

/* ----------Baseline Tracking----------*/
// Baseline follows slow drift (posture changes, belt shift)
// Very small value so baseline does NOT cancel breathing motion
static const float BASELINE_ALPHA = 0.0008f;

/* ----------Breath detection (small-signal tuned)----------*/
static const int THRESH_ON  = 2;     // trigger when |delta| >= 2
static const int THRESH_OFF = 1;     // end breath when |delta| <= 1
// Minimum time between breaths (ms)
// Prevents double-counting during a single inhale
static const uint32_t REFRACTORY_MS = 1500;

// Debug printing rate
static const uint32_t PRINT_MS = 250;

//STATE VARS
float filt = 0.0f;
float baseline = 0.0f;

bool inBreath = false;
uint32_t lastBreathMs = 0;

// ========================BPM smoothing: median of last N intervals===================
static const int MAX_INTERVALS = 6;
uint32_t intervals[MAX_INTERVALS];
int intervalCount = 0;

//~~~~~~~~~~~~~~~~~~~~~~~~~~HELPER FUNCTIONS~~~~~~~~~~~~~~~~~~~~~~~~~

// Store a new breath interval (ms) into a rolling buffer
void pushInterval(uint32_t dt) {
  if (intervalCount < MAX_INTERVALS) {
    intervals[intervalCount++] = dt;
  } else {
    // Shift older intervals left and add newest at end
    for (int i = 1; i < MAX_INTERVALS; i++) intervals[i - 1] = intervals[i];
    intervals[MAX_INTERVALS - 1] = dt;
  }
}

// Compute breaths-per-minute using the MEDIAN interval
// Median is more stable than average if one breath is irregular
float computeBPM_median() {
  if (intervalCount == 0) return 0.0f;

  uint32_t tmp[MAX_INTERVALS];
  for (int i = 0; i < intervalCount; i++) tmp[i] = intervals[i];

  // Simple sort (small array → low overhead)
  for (int i = 0; i < intervalCount - 1; i++) {
    for (int j = i + 1; j < intervalCount; j++) {
      if (tmp[j] < tmp[i]) {
        uint32_t t = tmp[i];
        tmp[i] = tmp[j];
        tmp[j] = t;
      }
    }
  }

  uint32_t med = tmp[intervalCount / 2];
  if (med == 0) return 0.0f;
  return 60000.0f / (float)med;
}
//@@@@@@@@@@@@@@ INIT SETUP @@@@@@@@@@@@@@@
void setup() {
  Serial.begin(BAUD);
  delay(500);
  Serial.println("Respiration breath test starting...");
  Serial.println("Wear snug (upper abdomen works best). Sit still 5–10s.");

  // Initialize filter and baseline using first reading
  int x0 = analogRead(SENSOR_PIN);
  filt = (float)x0;
  baseline = (float)x0;
}

void loop() {
  const uint32_t now = millis();
  const int raw = analogRead(SENSOR_PIN);   // Read raw analog sensor value (0–1023)

  // low-pass filter
  filt = (1.0f - FILTER_ALPHA) * filt + FILTER_ALPHA * (float)raw;

  // baseline drifts slowly when not in a breath
  if (!inBreath) {
    baseline = (1.0f - BASELINE_ALPHA) * baseline + BASELINE_ALPHA * filt;
  }
  
  // Difference between filtered signal and baseline
  const int delta = (int)lroundf(filt - baseline);
  // Magnitude of breathing signal (ignore direction)
  const int mag = abs(delta);

   /* ===== Breath Detection ===== */
  // detect start of breath
  if (!inBreath) {
    if (mag >= THRESH_ON && (now - lastBreathMs) > REFRACTORY_MS) {
      inBreath = true;

      //Calculate time since last breath to estimate BPM (breaths not beats, prob should rename this...)
      if (lastBreathMs != 0) {
        uint32_t dt = now - lastBreathMs;
        pushInterval(dt);
      }
      lastBreathMs = now;

      // Clean event line (easy to log)
      Serial.print("BREATH_START, t_ms=");
      Serial.print(now);
      Serial.print(", d=");
      Serial.print(delta);
      Serial.print(", BPM=");
      Serial.println(computeBPM_median(), 1);
    }
  // Detect end of breath
  } else {
    if (mag <= THRESH_OFF) {
      inBreath = false;
      Serial.print("BREATH_END, t_ms=");
      Serial.println(now);
    }
  }
//_______________CHAT SUGGESTION: ______________
  // Optional debug line every PRINT_MS
  static uint32_t lastPrint = 0;
  if (now - lastPrint >= PRINT_MS) {
    Serial.print("raw=");
    Serial.print(raw);
    Serial.print(" filt=");
    Serial.print((int)lroundf(filt));
    Serial.print(" base=");
    Serial.print((int)lroundf(baseline));
    Serial.print(" d=");
    Serial.print(delta);
    Serial.print(" |d|=");
    Serial.println(mag);
    lastPrint = now;
  }

  delay(SAMPLE_MS);
}
